{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "check:node": "node scripts/check-node-version.mjs",
    "dev": "vite",
    "build": "npm run check:i18n && tsc -b && vite build",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:i18n": "node scripts/check-i18n.mjs && npm run gen:i18n-keys",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "bench:task-list": "node scripts/bench-task-list.mjs",
    "preview": "vite preview",
    "gen:i18n-keys": "node scripts/gen-i18n-keys.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@fontsource/outfit": "^5.2.8",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "antd": "^6.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-resizable": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-resizable": "^4.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "ajv": "^6.14.0"
